[Unit]
Description=Issabel Dialer - Predictive dialer daemon
After=mariadb.service asterisk.service network-online.target
Wants=network-online.target
Requires=mariadb.service

[Service]
Type=forking
User=asterisk
Group=asterisk
WorkingDirectory=/opt/issabel/dialer

Environment="LANG=en_US.UTF-8"
Environment="LC_ALL=en_US.UTF-8"

PIDFile=/opt/issabel/dialer/dialerd.pid
ExecStart=/opt/issabel/dialer/dialerd
ExecStop=/bin/kill -SIGTERM $MAINPID
TimeoutStopSec=30
KillSignal=SIGTERM
KillMode=control-group

Restart=on-failure
RestartSec=10
RestartPreventExitStatus=0

StandardOutput=null
StandardError=journal
SyslogIdentifier=issabeldialer

[Install]
WantedBy=multi-user.target
